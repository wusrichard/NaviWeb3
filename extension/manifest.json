{
  "manifest_version": 3,
  "name": "NaviWeb3",
  "version": "1.1.0",
  "description": "DeFi 操作路徑 AI 顧問 — 讀取錢包持倉，給個人化建議",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NaviWeb3"
  },
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ]
}
